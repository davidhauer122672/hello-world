# ══════════════════════════════════════════════════════════════════════════
# Coastal Key Enterprise — Environment Variables Reference
# Copy to .dev.vars for local development (never commit actual values)
# ══════════════════════════════════════════════════════════════════════════

# ── API Gateway (ck-api-gateway) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
AIRTABLE_API_KEY=patxxxxx
WORKER_AUTH_TOKEN=your-secure-token-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ── Sentinel Webhook ──
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# ── Campaign Config (th-sentinel-campaign) ──
CAMPAIGN_OWNER_NAME=Your Name
CAMPAIGN_COMPANY_NAME=Your Company
CAMPAIGN_OFFICE_ADDRESS=123 Main St, City, ST
CAMPAIGN_TRANSFER_NUMBER=000-000-0000
CAMPAIGN_WEBSITE=www.example.com
CAMPAIGN_EMAIL=contact@example.com
CAMPAIGN_TRANSFER_ENDPOINT=tel:+10000000000

# ── Cloudflare (CI/CD) ──
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
