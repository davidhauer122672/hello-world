PORT=3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-password-here
EMAIL_FROM=noreply@yourbusiness.com

# Twilio SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
OWNER_PHONE_NUMBER=+1234567890

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEET_NAME=Appointments

# Buffer (optional — manual mode if omitted)
BUFFER_ACCESS_TOKEN=your-buffer-access-token
BUFFER_PROFILE_INSTAGRAM=profile-id
BUFFER_PROFILE_FACEBOOK=profile-id
BUFFER_PROFILE_LINKEDIN=profile-id
BUFFER_PROFILE_X=profile-id
BUFFER_PROFILE_ALIGNABLE=profile-id

# Meta Ads (optional — enables auto-boost and paid campaigns)
META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_PAGE_ID=your-page-id

# Atlas AI (optional — enables Atlas campaign management)
ATLAS_API_KEY=your-atlas-api-key

# Anthropic (for live call objection handling)
ANTHROPIC_API_KEY=sk-ant-...

# Site
SITE_URL=http://localhost:3000
BUSINESS_NAME=Coastal Key Treasure Coast Asset Management
CEO_EMAIL=ceo@coastalkey-pm.com

# Security
ADMIN_TOKEN=your-admin-secret-token
TEAM_ACCESS_CODE=your-team-access-code
CORS_ORIGIN=http://localhost:3000
