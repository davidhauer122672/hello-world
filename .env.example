# Coastal Key Assets - Environment Configuration
# Copy this file to .env and fill in your actual values

# Cloudflare R2 Public Bucket URL
R2_PUBLIC_URL=https://pub-[yours].r2.dev

# Cloudflare Worker Upload Proxy
WORKER_URL=https://image-ingestion-proxy.[yours].workers.dev

# Upload API Key (32-character secret for Worker auth)
UPLOAD_API_KEY=[your-32-char-string]

# Cloudflare Account (for S3-compatible direct access)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=coastal-key-assets
