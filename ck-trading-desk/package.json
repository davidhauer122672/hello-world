{
  "name": "ck-trading-desk",
  "version": "1.0.0",
  "private": true,
  "description": "CK Trading Desk — Coastal Key Enterprise Autonomous Financial Operations Platform",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "vite --port 3000",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "test": "node --test src/**/__tests__/**/*.test.js",
    "lint": "eslint src/",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.coastalkey.trading-desk",
    "productName": "CK Trading Desk",
    "copyright": "Copyright 2026 Coastal Key Enterprise",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "src/shared/**/*",
      "dist-renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.bmp"
    },
    "protocols": {
      "name": "CK Trading Desk",
      "schemes": ["ck-trading"]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.92.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.0",
    "vite": "^8.0.10",
    "wait-on": "^7.2.0"
  }
}
