{
  "name": "coastalkey-enterprise",
  "version": "1.0.0",
  "private": true,
  "description": "Coastal Key Enterprise AI Operations Platform — Monorepo",
  "workspaces": [
    "ck-api-gateway",
    "sentinel-webhook"
  ],
  "scripts": {
    "dev:gateway": "cd ck-api-gateway && npm run dev",
    "dev:sentinel": "cd sentinel-webhook && npm run dev",
    "deploy": "npm run deploy:gateway && npm run deploy:sentinel && npm run deploy:website && npm run deploy:cc",
    "deploy:gateway": "cd ck-api-gateway && npm run deploy",
    "deploy:sentinel": "cd sentinel-webhook && npm run deploy",
    "deploy:website": "npx wrangler pages deploy ck-website --project-name=coastalkey-pm",
    "deploy:cc": "npx wrangler pages deploy ck-command-center --project-name=ck-command-center",
    "test": "npm run test:gateway && npm run test:sentinel && npm run test:domain && npm run test:smoke",
    "test:gateway": "cd ck-api-gateway && npm test",
    "test:sentinel": "cd sentinel-webhook && npm test",
    "test:domain": "node --test tests/domain-validation.test.js",
    "test:smoke": "node --test tests/app-smoke.test.js",
    "test:domain:live": "LIVE_DOMAIN_TEST=1 node --test tests/domain-validation.test.js"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
