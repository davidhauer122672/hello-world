{
  "expo": {
    "name": "Coastal Key",
    "slug": "coastal-key",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "coastalkey",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1426"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coastalkey.pm",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show nearby properties on the map"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1426"
      },
      "package": "com.coastalkey.pm",
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "coastal-key-mobile"
      }
    }
  }
}
